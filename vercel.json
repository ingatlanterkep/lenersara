{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "outputDirectory": ".next",
  "regions": ["iad1"],
  "env": {
    "NEXT_PUBLIC_BACKEND_BASEURL": "https://api.ingatlan-terkep.hu"
  },
"routes": [
    { "src": "/xml/(.*)", "dest": "/api/xml/$1" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}